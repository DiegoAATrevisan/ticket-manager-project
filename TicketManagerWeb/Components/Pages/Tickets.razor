@page "/tickets"
@rendermode InteractiveServer
@inject ServicoTicket ServicoTicketService

<h3>Tickets</h3>

<div class="mb-4">
    <h5>Cadastrar</h5>
    <input class="form-control mb-2" type="number" placeholder="Quantidade" @bind="QuantidadeCadastro" />
    <input class="form-control mb-2" type="text" placeholder="CPF do funcionário" @bind="CpfCadastro" />
    <button class="btn btn-primary" @onclick="CadastrarTicketAsync">Cadastrar</button>
</div>

<div class="mb-4">
    <h5>Buscar tickets por CPF</h5>
    <input class="form-control mb-2" type="text" placeholder="CPF do funcionário" @bind="CpfBusca" />
    <button class="btn btn-secondary" @onclick="CarregarTicketsAsync">Buscar</button>
</div>

@if (!string.IsNullOrWhiteSpace(Mensagem))
{
    <div class="alert alert-info">@Mensagem</div>
}

@if (tickets.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Quantidade</th>
                <th>Data Cadastro</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Ticket ticket in tickets)
            {
                <tr>
                    <td>@ticket.Quantidade</td>
                    <td>@ticket.DataCadastro.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => PrepararEdicao(ticket)">Editar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (TicketEditando is not null)
{
    <div class="mb-4">
        <h5>Editar ticket</h5>
        <input class="form-control mb-2" type="number" placeholder="Quantidade" @bind="QuantidadeEdicao" />
        <input class="form-control mb-2" type="text" placeholder="CPF do funcionário" @bind="CpfEdicao" />
        <button class="btn btn-success" @onclick="SalvarEdicaoAsync">Salvar edição</button>
    </div>
}

@code {
    private int QuantidadeCadastro;
    private string CpfCadastro = string.Empty;

    private string CpfBusca = string.Empty;
    private string Mensagem = string.Empty;
    private List<Ticket> tickets = new();

    private Ticket? TicketEditando;
    private int QuantidadeEdicao;
    private string CpfEdicao = string.Empty;

    private async Task CadastrarTicketAsync()
    {
        try
        {
            Ticket ticket = new Ticket
            {
                Quantidade = QuantidadeCadastro
            };

            await ServicoTicketService.CadastrarTicket(ticket, CpfCadastro);

            Mensagem = "Ticket cadastrado com sucesso.";
            QuantidadeCadastro = 0;
            CpfCadastro = string.Empty;
        }
        catch (Exception ex)
        {
            Mensagem = $"Erro ao cadastrar ticket: {ex.Message}";
        }
    }

    private Task CarregarTicketsAsync()
    {
        try
        {
            tickets = ServicoTicketService.BuscarListaTicketsPorCpf(CpfBusca);

            Mensagem = tickets.Count > 0
                ? $"Encontrado(s) {tickets.Count} ticket(s) para o CPF informado."
                : "Nenhum ticket encontrado.";
        }
        catch (Exception ex)
        {
            Mensagem = $"Erro ao buscar ticket(s): {ex.Message}";
            tickets.Clear();
        }

        return Task.CompletedTask;
    }

    private void PrepararEdicao(Ticket ticket)
    {
        TicketEditando = ticket;
        QuantidadeEdicao = ticket.Quantidade;
        CpfEdicao = string.Empty;
        Mensagem = $"Ticket {ticket.Id} carregado para edição.";
    }

    private Task SalvarEdicaoAsync()
    {
        try
        {
            if (TicketEditando is null)
            {
                Mensagem = "Nenhum ticket carregado.";
                return Task.CompletedTask;
            }

            ServicoTicketService.Editar(
                TicketEditando.Id,
                QuantidadeEdicao,
                CpfEdicao
            );

            Mensagem = "Ticket atualizado com sucesso.";
            TicketEditando = null;

            return CarregarTicketsAsync();
        }
        catch (Exception ex)
        {
            Mensagem = $"Erro ao editar ticket: {ex.Message}";
        }

        return Task.CompletedTask;
    }
}