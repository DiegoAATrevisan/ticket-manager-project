@page "/tickets"
@rendermode InteractiveServer
@inject ServicoTicket ServicoTicketService

<h3>Tickets</h3>

<div class="mb-4">
    <h5>Buscar por funcionário</h5>
    <input class="form-control mb-2" type="number" placeholder="Id do funcionário" @bind="IdFuncionarioBusca" />
    <button class="btn btn-secondary" @onclick="CarregarTicketsAsync">Buscar</button>
</div>

@if (!string.IsNullOrWhiteSpace(Mensagem))
{
    <div class="alert alert-info">@Mensagem</div>
}

@if (tickets.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Id Funcionário</th>
                <th>Quantidade</th>
                <th>Situação</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in tickets)
            {
                <tr>
                    <td>@ticket.Id</td>
                    <td>@ticket.IdFuncionario</td>
                    <td>@ticket.Quantidade</td>
                    <td>@ticket.Situacao</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int IdFuncionarioBusca;
    private string Mensagem = string.Empty;
    private List<Ticket> tickets = new List<Ticket>();
    private Task CarregarTicketsAsync()
    {
        try
        {
            tickets = ServicoTicketService.BuscarListaTickets(IdFuncionarioBusca);

            Mensagem = tickets.Count > 0
                ? $"Encontrado(s) {tickets.Count} ticket(s) para o funcionário {IdFuncionarioBusca}."
                : "Nenhum ticket encontrado.";
        }
        catch (Exception ex)
        {
            Mensagem = $"Erro ao buscar ticket(s): {ex.Message}";
            tickets.Clear();
        }

        return Task.CompletedTask;
    }
}